# App
DEBUG=false

# Directories (defaults to ./uploads and ./outputs)
# UPLOAD_DIR=./uploads
# OUTPUT_DIR=./outputs
# MODEL_DIR=./models

# Database
DATABASE_URL=sqlite:///./transcriber.db

# Whisper model settings
WHISPER_MODEL=large-v3
# WHISPER_DEVICE=auto    # auto, cpu, cuda
# WHISPER_COMPUTE_TYPE=auto  # auto, int8, float16, float32

# Diarization (optional - requires HF token)
DIARIZATION_ENABLED=false
# HUGGINGFACE_TOKEN=hf_...

# Limits
# MAX_FILE_SIZE_MB=500
# MAX_URL_DOWNLOAD_SIZE_MB=200
# REQUEST_TIMEOUT_SECONDS=30
